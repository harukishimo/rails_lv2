<% local_demo_enabled = Rails.configuration.x.local_demo_enabled %>

<section class="auth-layout">
  <div class="auth-panel">
    <p class="eyebrow">Skill Evidence Hub</p>
    <h1>ログイン</h1>
    <% if local_demo_enabled %>
      <p>デモ用seedを投入すると、下記アカウントで主要ロールの画面を確認できます。</p>
    <% else %>
      <p>社内評価基準レビューと評価面談の進行状況を確認します。</p>
    <% end %>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |form| %>
      <div class="field">
        <%= form.label :email, "メールアドレス" %>
        <%= form.email_field :email, autofocus: true, autocomplete: "email" %>
      </div>

      <div class="field">
        <%= form.label :password, "パスワード" %>
        <%= form.password_field :password, autocomplete: "current-password" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <label class="checkbox-field">
          <%= form.check_box :remember_me %>
          <span>ログイン状態を保持する</span>
        </label>
      <% end %>

      <%= form.submit "ログイン", class: "button button--primary" %>
    <% end %>
  </div>

  <% if local_demo_enabled %>
    <aside class="auth-panel auth-panel--secondary">
      <h2>デモアカウント</h2>
      <dl class="demo-accounts">
        <div>
          <dt>管理者</dt>
          <dd>admin@example.com</dd>
        </div>
        <div>
          <dt>受験者</dt>
          <dd>candidate@example.com</dd>
        </div>
        <div>
          <dt>評価官</dt>
          <dd>examiner@example.com</dd>
        </div>
      </dl>
      <p>パスワードはいずれも <code>password123</code> です。</p>
    </aside>
  <% end %>
</section>
