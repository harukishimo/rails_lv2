<div class="<%= ui_class(:page_header) %>">
  <div>
    <h1 class="<%= ui_class(:page_title) %>">受験表明一覧</h1>
    <p class="<%= ui_class(:page_description) %>">自分の受験状況、レビュー依頼、面談応募へ進む起点です。</p>
  </div>
  <% if current_user.candidate? %>
    <%= link_to "受験表明を作成", new_exam_application_path, class: button_classes %>
  <% end %>
</div>

<%= form_with url: exam_applications_path, method: :get, class: ui_class(:toolbar) do |form| %>
  <div class="<%= ui_class(:field) %>">
    <%= form.label :keyword, "対象キーワード" %>
    <%= form.search_field :keyword, value: params[:keyword] %>
  </div>
  <div class="<%= ui_class(:field) %>">
    <%= form.label :statuses, "ステータス" %>
    <%= status_filter_checkboxes(ExamApplication) %>
  </div>
  <div class="<%= ui_class(:field) %>">
    <%= form.label :result, "結果" %>
    <%= form.select :result, options_for_select(enum_options_for(ExamApplication, :result), params[:result]), include_blank: "すべて" %>
  </div>
  <%= form.submit "検索" %>
<% end %>

<% if @exam_applications.any? %>
  <div class="<%= ui_class(:table_wrap) %>">
    <table>
      <thead>
        <tr>
          <th>受験</th>
          <th>状態</th>
          <th>結果</th>
          <th>受験者</th>
          <th>評価期</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @exam_applications.each do |exam_application| %>
          <tr>
            <td>
              <%= evaluation_target_compact_name(exam_application.evaluation_target) %>
              <div class="<%= ui_class(:page_description) %>">受験ID: <%= exam_application.id %></div>
            </td>
            <td><%= status_badge(exam_application.status) %></td>
            <td><%= status_badge(exam_application.result) %></td>
            <td><%= exam_application.candidate.name %>&lt;<%= exam_application.candidate.email %>&gt;</td>
            <td><%= exam_application.evaluation_period.name %></td>
            <td><%= link_to "詳細", exam_application_path(exam_application), class: button_classes(:secondary) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <%= empty_state("受験表明はまだありません。受験対象を選んで受験表明を作成してください。") %>
<% end %>
