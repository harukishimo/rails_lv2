<div class="<%= ui_class(:page_header) %>">
  <div>
    <h1 class="<%= ui_class(:page_title) %>"><%= @exam_application.display_name %></h1>
    <p class="<%= ui_class(:page_description) %>">受験表明の詳細、レビュー依頼、面談応募を確認します。</p>
  </div>
  <%= link_to "一覧へ戻る", exam_applications_path, class: button_classes(:secondary) %>
</div>

<dl class="<%= ui_class(:detail_list) %>">
  <dt>受験ID</dt>
  <dd><%= @exam_application.id %></dd>
  <dt>ステータス</dt>
  <dd><%= status_badge(@exam_application.status) %></dd>
  <dt>結果</dt>
  <dd><%= status_badge(@exam_application.result) %></dd>
  <dt>受験者</dt>
  <dd><%= @exam_application.candidate.name %>&lt;<%= @exam_application.candidate.email %>&gt;</dd>
  <dt>受験対象</dt>
  <dd><%= evaluation_target_compact_name(@exam_application.evaluation_target) %></dd>
  <dt>評価期</dt>
  <dd><%= @exam_application.evaluation_period.name %></dd>
</dl>

<div class="<%= ui_class(:panel) %>">
  <h2>次の操作</h2>
  <div class="<%= ui_class(:actions) %>">
    <% if current_user.candidate? && @exam_application.candidate_id == current_user.id && !@exam_application.closed? %>
      <%= link_to "レビュー依頼を作成", new_exam_application_review_application_path(@exam_application), class: button_classes %>
      <% if @exam_application.interview_application.present? %>
        <%= link_to "面談応募を確認", interview_application_path(@exam_application.interview_application), class: button_classes(:secondary) %>
      <% elsif @exam_application.interview_permitted? %>
        <%= link_to "面談応募へ進む", new_exam_application_interview_application_path(@exam_application), class: button_classes(:secondary) %>
      <% else %>
        <p class="<%= ui_class(:muted_text) %>">面談応募は評価官が許可すると作成できます。</p>
      <% end %>
    <% end %>
    <% if policy(@exam_application).permit_interview? %>
      <%= button_to "面談を許可する", permit_interview_exam_application_path(@exam_application), method: :patch, class: button_classes %>
    <% end %>
  </div>
</div>

<section class="<%= ui_class(:auth_form) %>">
  <div class="<%= ui_class(:panel) %>">
    <h2>レビュー依頼</h2>
    <% if @exam_application.review_applications.any? %>
      <ul>
        <% @exam_application.review_applications.each do |review_application| %>
          <li>
            <%= link_to review_application.display_name, review_application_path(review_application) %>
            <%= status_badge(review_application.status) %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <%= empty_state("レビュー依頼はまだありません。") %>
    <% end %>
  </div>

  <div class="<%= ui_class(:panel) %>">
    <h2>面談応募</h2>
    <% if @exam_application.interview_application.present? %>
      <%= link_to @exam_application.interview_application.display_name, interview_application_path(@exam_application.interview_application) %>
      <%= status_badge(@exam_application.interview_application.status) %>
    <% else %>
      <%= empty_state("面談応募はまだありません。") %>
    <% end %>
  </div>

  <div class="<%= ui_class(:panel) %>">
    <h2>取得資格</h2>
    <% if @exam_application.user_qualification.present? %>
      <p><%= evaluation_target_compact_name(@exam_application.user_qualification.evaluation_target) %> / <%= @exam_application.user_qualification.acquired_on %></p>
    <% else %>
      <%= empty_state("合格判定後に取得資格へ反映されます。") %>
    <% end %>
  </div>

  <%= render "shared/status_change_events", record: @exam_application %>
</section>
