<div class="<%= ui_class(:page_header) %>">
  <div>
    <h1 class="<%= ui_class(:page_title) %>"><%= @review_application.display_name %></h1>
    <p class="<%= ui_class(:page_description) %>">status=<%= @review_application.status %></p>
  </div>
  <div class="<%= ui_class(:actions) %>">
    <% if policy(@review_application.exam_application).show? %>
      <%= link_to "受験へ戻る", exam_application_path(@review_application.exam_application), class: button_classes(:secondary) %>
    <% else %>
      <%= link_to "レビューキューへ戻る", examiner_review_queue_index_path, class: button_classes(:secondary) %>
    <% end %>
    <% if policy(@review_application).edit? %>
      <%= link_to "編集", edit_review_application_path(@review_application), class: button_classes(:secondary) %>
    <% end %>
    <% if policy(@review_application).cancel? %>
      <%= button_to "レビュー依頼を取り消す",
                    cancel_review_application_path(@review_application),
                    method: :patch,
                    params: { review_application: { cancel_reason: "画面から取り消し" } },
                    class: button_classes(:danger) %>
    <% end %>
  </div>
</div>

<dl class="<%= ui_class(:detail_list) %>">
  <dt>状態</dt>
  <dd><%= status_badge(@review_application.status) %></dd>
  <dt>受験者</dt>
  <dd><%= @review_application.exam_application.candidate.name %></dd>
  <dt>受験対象</dt>
  <dd><%= @review_application.exam_application.evaluation_target.display_name %></dd>
  <dt>アピール</dt>
  <dd><%= sanitize(@review_application.rendered_appeal_html) %></dd>
</dl>

<section class="<%= ui_class(:auth_form) %>">
  <div class="<%= ui_class(:panel) %>">
    <h2>提出物</h2>
    <% if @review_application.submissions.any? %>
      <ul>
        <% @review_application.submissions.each do |submission| %>
          <li>submission=<%= submission.title %>:<%= submission.kind %> <%= submission.github_url %></li>
        <% end %>
      </ul>
    <% else %>
      <%= empty_state("提出物はまだありません。") %>
    <% end %>
  </div>

  <div class="<%= ui_class(:panel) %>">
    <h2>レビューコメント</h2>
    <% persisted_comments = @review_application.review_comments.reject(&:new_record?) %>
    <% if persisted_comments.any? %>
      <% persisted_comments.each do |comment| %>
        <div class="<%= ui_class(:panel) %>">
          <strong><%= comment.examiner.name %></strong>
          <div><%= sanitize(comment.rendered_body_html) %></div>
        </div>
      <% end %>
    <% else %>
      <%= empty_state("レビューコメントはまだありません。") %>
    <% end %>

    <% if policy(@review_application).comment? %>
      <%= form_with model: [@review_application, @review_comment] do |form| %>
        <div class="<%= ui_class(:field) %>">
          <%= form.label :body_markdown, "コメント" %>
          <%= form.text_area :body_markdown %>
        </div>
        <div class="<%= ui_class(:form_actions) %>">
          <%= form.submit "コメントを登録" %>
        </div>
      <% end %>
    <% end %>
  </div>

  <div class="<%= ui_class(:panel) %>">
    <h2>判定</h2>
    <% persisted_decisions = @review_application.review_decisions.reject(&:new_record?) %>
    <% if persisted_decisions.any? %>
      <ul>
        <% persisted_decisions.each do |decision| %>
          <li><%= status_badge(decision.decision) %> <%= decision.examiner.name %></li>
        <% end %>
      </ul>
    <% else %>
      <%= empty_state("判定はまだありません。") %>
    <% end %>

    <% if policy(@review_application).decide? %>
      <%= form_with model: [@review_application, @review_decision] do |form| %>
        <div class="<%= ui_class(:field) %>">
          <%= form.label :decision, "判定" %>
          <%= form.select :decision, ReviewDecision.decisions.keys.map { |decision| [decision, decision] } %>
        </div>
        <div class="<%= ui_class(:field) %>">
          <%= form.label :reason_markdown, "理由" %>
          <%= form.text_area :reason_markdown %>
        </div>
        <div class="<%= ui_class(:form_actions) %>">
          <%= form.submit "レビュー判定を登録" %>
        </div>
      <% end %>
    <% end %>
  </div>

  <%= render "shared/status_change_events", record: @review_application %>
</section>
