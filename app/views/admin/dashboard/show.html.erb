<section class="<%= ui_class(:page_header) %>">
  <div>
    <p class="<%= ui_class(:eyebrow) %>">Admin</p>
    <h1 class="<%= ui_class(:page_title) %>">管理</h1>
  </div>
</section>

<section class="<%= ui_class(:dashboard_grid) %>">
  <article class="<%= ui_class(:panel) %>">
    <h2>受験対象取込</h2>
    <p>CSV/XLSXから受験対象マスタをpreview/importします。</p>
    <%= link_to "取込を開く", new_admin_evaluation_target_import_path, class: button_classes %>
  </article>

  <article class="<%= ui_class(:panel) %>">
    <h2>帳票出力</h2>
    <p>受験対象、レビュー結果、提出状況、取得資格をCSV/XLSXで出力します。</p>
    <%= link_to "帳票を開く", admin_exports_path, class: button_classes(:secondary) %>
  </article>
</section>
