<section class="page-heading">
  <div>
    <p class="eyebrow">Admin / Import</p>
    <h1>受験対象取込</h1>
  </div>
  <%= link_to "管理へ戻る", admin_dashboard_path, class: "button" %>
</section>

<section class="panel">
  <h2>CSV/XLSXファイル</h2>
  <p>必須列: skill_area, programming_language, skill_level, version, external_knowledge_url または external_knowledge_key</p>

  <% if @import_error.present? %>
    <div class="form-errors" role="alert">
      <h2 class="form-errors__title">取込内容を確認してください</h2>
      <ul>
        <li><%= @import_error %></li>
      </ul>
    </div>
  <% end %>

  <div class="actions">
    <%= form_with url: preview_admin_evaluation_target_import_path, multipart: true, local: true, class: "inline-form" do |form| %>
      <%= form.file_field :file, accept: ".csv,.xlsx" %>
      <%= form.submit "プレビュー", class: "button" %>
    <% end %>

    <%= form_with url: import_admin_evaluation_target_import_path, multipart: true, local: true, class: "inline-form" do |form| %>
      <%= form.file_field :file, accept: ".csv,.xlsx" %>
      <%= form.submit "取込実行", class: "button button--primary" %>
    <% end %>
  </div>
</section>

<% if @result.present? %>
  <section class="panel">
    <div class="toolbar">
      <div>
        <p class="eyebrow"><%= @result.mode == :preview ? "Preview" : "Import" %></p>
        <h2>取込結果</h2>
      </div>
    </div>

    <dl class="detail-list">
      <div>
        <dt>処理行数</dt>
        <dd><%= @result.processed_count %></dd>
      </div>
      <div>
        <dt>作成</dt>
        <dd><%= @result.created_count %></dd>
      </div>
      <div>
        <dt>更新</dt>
        <dd><%= @result.updated_count %></dd>
      </div>
      <div>
        <dt>エラー</dt>
        <dd><%= @result.failed_count %></dd>
      </div>
    </dl>

    <table class="data-table">
      <thead>
        <tr>
          <th>行</th>
          <th>結果</th>
          <th>受験対象</th>
          <th>エラー</th>
        </tr>
      </thead>
      <tbody>
        <% @result.rows.each do |row| %>
          <tr>
            <td><%= row.row_number %></td>
            <td><%= status_badge(row.status) %></td>
            <td><%= row.display_name.presence || "-" %></td>
            <td>
              <% if row.errors.present? %>
                <ul class="compact-list">
                  <% row.errors.each do |error| %>
                    <li><%= error %></li>
                  <% end %>
                </ul>
              <% else %>
                -
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
<% end %>
