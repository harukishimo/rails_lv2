<div class="<%= ui_class(:page_header) %>">
  <div>
    <h1 class="<%= ui_class(:page_title) %>">受験対象</h1>
    <p class="<%= ui_class(:page_description) %>">言語・カテゴリ、Lvを検索します。</p>
  </div>
</div>

<%= form_with url: evaluation_targets_path, method: :get, class: ui_class(:toolbar) do |form| %>
  <div class="<%= ui_class(:field) %>">
    <%= form.label :keyword, "キーワード" %>
    <%= form.search_field :keyword, value: params[:keyword] %>
  </div>
  <% if current_user.admin? %>
    <div class="<%= ui_class(:field) %>">
      <%= form.label :active, "有効状態" %>
      <%= form.select :active, options_for_select([["すべて", ""], ["有効", "true"], ["無効", "false"]], params[:active]) %>
    </div>
  <% end %>
  <%= form.submit "検索" %>
<% end %>

<% if @evaluation_targets.any? %>
  <div class="<%= ui_class(:table_wrap) %>">
    <table>
      <thead>
        <tr>
          <th>言語・カテゴリ</th>
          <th>Lv</th>
          <% if current_user.admin? %>
            <th>状態</th>
            <th>外部キー</th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% @evaluation_targets.each do |target| %>
          <tr>
            <td><%= evaluation_target_language_label(target) %></td>
            <td><%= evaluation_target_level_label(target) %></td>
            <% if current_user.admin? %>
              <td><%= status_badge(target.active? ? "active" : "inactive") %></td>
              <td><%= target.external_knowledge_key %></td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <%= empty_state("受験対象が見つかりません。検索条件を変更してください。") %>
<% end %>
