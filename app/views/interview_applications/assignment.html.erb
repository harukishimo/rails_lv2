<div class="<%= ui_class(:page_header) %>">
  <div>
    <h1 class="<%= ui_class(:page_title) %>">面談評価官の割り振り</h1>
    <p class="<%= ui_class(:page_description) %>">現在の面談評価官: <%= @interview_application.assigned_examiner_name %></p>
  </div>
  <%= link_to "面談へ戻る", interview_application_path(@interview_application), class: button_classes(:secondary) %>
</div>

<%= error_summary(@interview_application) %>

<div class="<%= ui_class(:panel) %>">
  <p>面談対応数が少ない評価官を自動提案し、下記リストの初期値に設定しています。</p>
  <p class="<%= ui_class(:muted_text) %>">
    自動提案:
    <%= @suggested_examiners.map(&:display_name).presence&.join(" / ") || "候補なし" %>
  </p>
</div>

<div class="<%= ui_class(:panel) %>">
  <%= form_with model: @interview_application, url: assignment_interview_application_path(@interview_application), method: :patch do |form| %>
    <div class="<%= ui_class(:field) %>">
      <%= form.label :assigned_examiner_profile_id, "面談評価官1" %>
      <%= form.collection_select :assigned_examiner_profile_id,
                                 @examiner_profiles,
                                 :id,
                                 :display_name,
                                 selected: @selected_primary_examiner_id,
                                 prompt: "選択してください" %>
    </div>
    <div class="<%= ui_class(:field) %>">
      <%= form.label :secondary_assigned_examiner_profile_id, "面談評価官2" %>
      <%= form.collection_select :secondary_assigned_examiner_profile_id,
                                 @examiner_profiles,
                                 :id,
                                 :display_name,
                                 selected: @selected_secondary_examiner_id,
                                 prompt: "選択してください" %>
    </div>
    <div class="<%= ui_class(:field) %>">
      <%= form.label :assignment_override_reason, "変更理由" %>
      <%= form.text_area :assignment_override_reason %>
    </div>
    <div class="<%= ui_class(:form_actions) %>">
      <%= form.submit "面談評価官を確定" %>
    </div>
  <% end %>
</div>
