<div class="<%= ui_class(:page_header) %>">
  <div>
    <h1 class="<%= ui_class(:page_title) %>"><%= @interview_application.display_name %></h1>
    <p class="<%= ui_class(:page_description) %>">面談評価官: <%= @interview_application.assigned_examiner_name %></p>
  </div>
  <div class="<%= ui_class(:actions) %>">
    <% if policy(@interview_application.exam_application).show? %>
      <%= link_to "受験へ戻る", exam_application_path(@interview_application.exam_application), class: button_classes(:secondary) %>
    <% else %>
      <%= link_to "受験者検索へ戻る", examiner_candidates_path, class: button_classes(:secondary) %>
    <% end %>
    <% if policy(@interview_application).assignment? %>
      <%= link_to "面談評価官を割り振る", assignment_interview_application_path(@interview_application), class: button_classes %>
    <% end %>
    <% if policy(@interview_application).decide_result? %>
      <%= link_to "面談結果を登録", "#interview-result", class: button_classes %>
    <% end %>
  </div>
</div>

<dl class="<%= ui_class(:detail_list) %>">
  <dt>状態</dt>
  <dd><%= status_badge(@interview_application.status) %></dd>
  <dt>受験者</dt>
  <dd><%= @interview_application.exam_application.candidate.name %></dd>
  <dt>受験対象</dt>
  <dd><%= evaluation_target_compact_name(@interview_application.exam_application.evaluation_target) %></dd>
  <dt>面接官</dt>
  <dd><%= @interview_application.assigned_examiner_name %></dd>
</dl>

<section class="<%= ui_class(:auth_form) %>">
  <div class="<%= ui_class(:panel) %>">
    <h2>希望日時</h2>
    <% persisted_schedules = @interview_application.interview_schedules.reject(&:new_record?) %>
    <% if persisted_schedules.any? %>
      <ul>
        <% persisted_schedules.each do |schedule| %>
          <li>
            希望日時: <%= schedule.display_name %>
            <%= status_badge(schedule.status) %>
            <% if policy(schedule).approve? %>
              <%= button_to "承認", approve_interview_schedule_path(schedule), method: :patch, class: button_classes %>
            <% end %>
            <% if policy(schedule).reject? %>
              <%= button_to "差し戻し", reject_interview_schedule_path(schedule), method: :patch, class: button_classes(:danger) %>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <%= empty_state("希望日時はまだ登録されていません。") %>
    <% end %>

    <% if policy(@interview_application).schedule? %>
      <%= form_with model: [@interview_application, @interview_schedule] do |form| %>
        <div class="<%= ui_class(:field) %>">
          <%= form.label :starts_at, "開始日時" %>
          <%= form.datetime_field :starts_at, step: 15.minutes %>
        </div>
        <div class="<%= ui_class(:field) %>">
          <%= form.label :ends_at, "終了日時" %>
          <%= form.datetime_field :ends_at, step: 15.minutes %>
        </div>
        <div class="<%= ui_class(:field) %>">
          <%= form.label :timezone, "タイムゾーン" %>
          <%= form.text_field :timezone, value: "Asia/Tokyo" %>
        </div>
        <div class="<%= ui_class(:form_actions) %>">
          <%= form.submit "希望日時を登録" %>
        </div>
      <% end %>
    <% end %>
  </div>

  <div id="interview-result" class="<%= ui_class(:panel) %>">
    <h2>面談結果</h2>
    <% if @persisted_interview_result.present? %>
      <p><%= status_badge(@persisted_interview_result.result) %></p>
      <div><%= sanitize(@persisted_interview_result.rendered_comment_html) %></div>
    <% else %>
      <%= empty_state("面談結果はまだ登録されていません。") %>
    <% end %>

    <% if policy(@interview_application).decide_result? %>
      <%= form_with model: @interview_result, url: interview_application_interview_result_path(@interview_application) do |form| %>
        <div class="<%= ui_class(:field) %>">
          <%= form.label :result, "判定" %>
          <%= form.select :result, enum_options_for(InterviewResult, :result) %>
        </div>
        <div class="<%= ui_class(:field) %>">
          <%= form.label :comment_markdown, "コメント" %>
          <%= form.text_area :comment_markdown %>
        </div>
        <div class="<%= ui_class(:form_actions) %>">
          <%= form.submit "面談結果を登録" %>
        </div>
      <% end %>
    <% end %>
  </div>

  <%= render "shared/status_change_events", record: @interview_application %>
</section>
