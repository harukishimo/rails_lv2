# frozen_string_literal: true

# Ridgepole is the source of truth for application-managed database schema.
# Domain tables will be added by feature Issues. Rails internal tables remain
# managed by Rails itself where required.

create_table "users", force: :cascade do |t|
  t.string "name", null: false
  t.string "email", null: false
  t.string "encrypted_password", null: false, default: ""
  t.datetime "remember_created_at"
  t.boolean "active", null: false, default: true
  t.datetime "last_sign_in_at"
  t.integer "lock_version", null: false, default: 0
  t.timestamps null: false

  t.index [ "active" ], name: "index_users_on_active"
  t.index [ "email" ], name: "index_users_on_email", unique: true
end

create_table "refresh_tokens", force: :cascade do |t|
  t.references "user", null: false
  t.string "token_digest", null: false
  t.datetime "expires_at", null: false
  t.datetime "revoked_at"
  t.timestamps null: false

  t.index [ "token_digest" ], name: "index_refresh_tokens_on_token_digest", unique: true
  t.index [ "user_id", "revoked_at" ], name: "index_refresh_tokens_on_user_id_and_revoked_at"
end

create_table "roles", force: :cascade do |t|
  t.string "code", null: false
  t.string "name", null: false
  t.boolean "active", null: false, default: true
  t.timestamps null: false

  t.index [ "active" ], name: "index_roles_on_active"
  t.index [ "code" ], name: "index_roles_on_code", unique: true
end

create_table "user_roles", force: :cascade do |t|
  t.references "user", null: false, index: false
  t.references "role", null: false, index: false
  t.timestamps null: false

  t.index [ "role_id", "user_id" ], name: "index_user_roles_on_role_id_and_user_id"
  t.index [ "user_id", "role_id" ], name: "index_user_roles_on_user_id_and_role_id", unique: true
end

create_table "examiner_profiles", force: :cascade do |t|
  t.references "user", null: false, index: false
  t.string "display_name", null: false
  t.boolean "active", null: false, default: true
  t.timestamps null: false

  t.index [ "active" ], name: "index_examiner_profiles_on_active"
  t.index [ "user_id" ], name: "index_examiner_profiles_on_user_id", unique: true
end

create_table "examiner_skill_capabilities", force: :cascade do |t|
  t.references "examiner_profile", null: false, index: false
  t.bigint "evaluation_target_id", null: false
  t.boolean "active", null: false, default: true
  t.timestamps null: false

  t.index [ "evaluation_target_id", "active" ], name: "index_examiner_skill_capabilities_on_target_and_active"
  t.index [ "examiner_profile_id", "evaluation_target_id" ],
          name: "index_examiner_skill_capabilities_on_profile_and_target",
          unique: true
end
