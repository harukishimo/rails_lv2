# frozen_string_literal: true

# Ridgepole is the source of truth for application-managed database schema.
# Keep this file as the Ridgepole entrypoint and define each table in
# db/schemas/tables/*.schema.

Dir[File.join(__dir__, "schemas/tables/*.schema")].sort.each do |schema_path|
  instance_eval(File.read(schema_path), schema_path)
end
