create_table "programming_languages", force: :cascade do |t|
  t.string "name", null: false
  t.boolean "active", null: false, default: true
  t.datetime "deleted_at"
  t.timestamps null: false

  t.index [ "active", "name" ], name: "index_programming_languages_on_active_and_name"
  t.index [ "deleted_at" ], name: "index_programming_languages_on_deleted_at"
  t.index [ "name" ], name: "index_programming_languages_on_name", unique: true
end
