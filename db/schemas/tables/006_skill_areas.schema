create_table "skill_areas", force: :cascade do |t|
  t.string "name", null: false
  t.integer "display_order", null: false, default: 0
  t.boolean "active", null: false, default: true
  t.datetime "deleted_at"
  t.timestamps null: false

  t.index [ "active", "display_order" ], name: "index_skill_areas_on_active_and_display_order"
  t.index [ "deleted_at" ], name: "index_skill_areas_on_deleted_at"
  t.index [ "name" ], name: "index_skill_areas_on_name", unique: true
end
